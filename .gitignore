# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

### Ruby / Bundler
/.bundle/
/vendor/bundle/
/vendor/cache/

# Old project-specific cache dir (keep if you use it)
.bundle_cache/

### Environment / secrets
# Ignore all dotenv files (keep .env.example committed)
/.env
/.env.*
!/.env.example

# Rails master key (never commit)
/config/master.key

# Encrypted credentials are committed; ignore per-environment keys if you ever create them
/config/credentials/*.key

### Rails runtime files
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep

/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

/tmp/cache/*
!/tmp/cache/
!/tmp/cache/.keep

### ActiveStorage / uploads / databases
/storage/*
!/storage/.keep

/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# SQLite databases (if you ever create them under different paths)
*.sqlite3
*.sqlite3-*

### Assets / build outputs
/public/assets/
/public/packs/
/public/packs-test/
/public/vite/

### Test artifacts / coverage
/coverage/
/spec/examples.txt
/capybara-*
/tmp/screenshots/

### Debugging
.byebug_history
.ruby-gemset

### Docs / generated binaries
*.pptx
*.ppt
*.docx

### Node (not currently used, but safe to ignore if added later)
/node_modules/
/yarn-error.log
/npm-debug.log*
/pnpm-debug.log*

### IDE / OS
.idea/
.DS_Store

# If you add these tools later
.kamal/
